# ============================================================
# Lume — Environment Variables
# ============================================================
#
# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit it.
#
# VITE_* vars ship to the browser. NEVER put secrets here.
# Server-only secrets go in Supabase Edge Function secrets,
# documented below for reference.
# ============================================================


# ----- Client-side (Vite, safe for browser) -----------------

# Supabase project URL
# Find at: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=your-project

# Supabase anon (public) key
# Find at: Supabase Dashboard → Project Settings → API → Project API keys → anon public
# This is safe to ship to the browser — RLS policies protect data.
VITE_SUPABASE_ANON_KEY=your_anon_key

# App base URL (used for magic link redirects)
# Local dev: http://localhost:5173
# Production: https://your-deployed-url.vercel.app
VITE_APP_URL=http://localhost:5173

# Demo account credentials (powers the "login as demo user" button on /sign-in).
# Optional — fall back to demo@lume.app / lume2026 if unset. These ship to the
# browser so use a throwaway password reserved for the seeded demo account.
# Create the user in Supabase Dashboard → Auth → Users, and make sure password
# sign-in is enabled in Auth → Providers → Email.
VITE_DEMO_EMAIL=demo@lume.app
VITE_DEMO_PASSWORD=lume2026


# ============================================================
# Server-side secrets (DO NOT put in this .env file)
# ============================================================
#
# These go in Supabase Edge Function secrets, set via the CLI:
#   supabase secrets set PERFECTCORP_API_KEY=xxx
#   supabase secrets set GEMINI_API_KEY=xxx
#
# Or via the Supabase dashboard:
#   Project Settings → Edge Functions → Secrets
#
# They are documented here only so you know what's needed.
# ============================================================

# Perfect Corp YouCam API key
# Get from: https://yce.perfectcorp.com/api-console/en/api-keys/
# Hackathon participants get 1,000 free units on sign-up
# PERFECTCORP_API_KEY=

# Google Gemini API key
# Get from: https://aistudio.google.com/apikey
# Model used: gemini-2.5-flash
# GEMINI_API_KEY=

# Supabase service role key (server-only)
# Find at: Supabase Dashboard → Project Settings → API → service_role
# Used by Edge Functions for admin DB operations that bypass RLS
# SUPABASE_SERVICE_ROLE_KEY=